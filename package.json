{
  "name": "pharos-agent-transaction-firewall",
  "version": "1.0.0",
  "description": "Pre-execution safety firewall for AI agents on Pharos.",
  "main": "dist/inspect-transaction.js",
  "bin": {
    "pharos-firewall": "dist/inspect-transaction.js"
  },
  "scripts": {
    "build": "tsc",
    "check": "npm run build && node --check dist/inspect-transaction.js",
    "inspect": "node dist/inspect-transaction.js",
    "demo:block": "node dist/inspect-transaction.js --fixture unlimited-approval",
    "demo:warn": "node dist/inspect-transaction.js --fixture safe-transfer"
  },
  "keywords": [
    "pharos",
    "agent",
    "skill",
    "blockchain",
    "security",
    "firewall",
    "calldata",
    "approval"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
